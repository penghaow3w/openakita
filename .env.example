# OpenAkita 配置
# 复制此文件为 .env 并修改配置

# === 必需配置 ===
# API Key (至少配置一个)
OPENAKITA_API_KEY=sk-your-api-key-here

# === LLM 配置 ===
# 提供商: openai | anthropic | ollama
OPENAKITA_LLM_PROVIDER=openai
# 模型名
OPENAKITA_LLM_MODEL=gpt-4o-mini
# 自定义 API 地址 (可选，用于兼容 OpenAI 的代理)
OPENAKITA_LLM_BASE_URL=

# === 人格配置 ===
# 可选: assistant | butler | jarvis | teacher | counselor | writer | analyst | sage
OPENAKITA_PERSONALITY=assistant

# === 存储配置 ===
OPENAKITA_DB_PATH=./data/openakita.db
OPENAKITA_VECTOR_DB_PATH=./data/vectors

# === RAG (知识检索) 配置 ===
OPENAKITA_EMBEDDING_MODEL=text-embedding-3-small
OPENAKITA_CHUNK_SIZE=512
OPENAKITA_TOP_K=5

# === 自我进化 (RL) 配置 ===
OPENAKITA_ENABLE_OPTIMIZE=true
OPENAKITA_LEARNING_RATE=0.1
OPENAKITA_FEEDBACK_WINDOW=50

# === 记忆配置 ===
OPENAKITA_PERSISTENT_MEMORY=true
OPENAKITA_MEMORY_TTL_DAYS=90

# === 技能学习 ===
OPENAKITA_SKILL_LEARNING=true
OPENAKITA_AUTO_FIX=true

# === 平台集成 ===
# web, discord, slack, telegram, wechat, whatsapp
OPENAKITA_PLATFORMS=web